{
	"type": "module",
	"name": "torrent-client",
	"private": true,
	"description": "Webtorrent client for Hayase",
	"main": "index.ts",
	"version": "1.0.0",
	"packageManager": "pnpm@10.28.0",
	"devDependencies": {
		"@types/node": "^25.9.3",
		"eslint-config-standard-universal": "^1.0.10",
		"protobufjs-cli": "^2.5.4",
		"typescript": "^5.9.3",
		"undici-types": "^8.5.0"
	},
	"scripts": {
		"build": "tsc",
