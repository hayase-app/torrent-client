		"fast-xml-parser": "^5.9.0",
		"matroska-metadata": "^1.0.12",
		"multicast-dns": "^7.2.5",
		"native": "github:hayase-app/native",
		"network-address": "^1.1.2",
		"nzb-file": "^1.1.18",
		"nzb-parser": "1.0.4",
		"protobufjs": "8.6.2",
		"webtorrent": "^3.0.16"
